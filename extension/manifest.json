{
    "manifest_version": 3,
    "name": "WMS Token Sync",
    "version": "1.0",
    "description": "Tự động đồng bộ token từ internal.thuocsi.vn sang proxy local",
    "permissions": ["cookies", "storage", "notifications"],
    "host_permissions": [
        "https://internal.thuocsi.vn/*",
        "http://localhost/*",
        "https://localhost/*"
    ],
    "action": {
        "default_popup": "popup.html",
        "default_icon": "icon.png"
    },
    "background": {
        "service_worker": "background.js"
    },
    "icons": {
        "128": "icon.png"
    }
}
